# Normalise line endings for text/code so the repo stays tidy across OSes.
*.gd     text eol=lf
*.tscn   text eol=lf
*.tres   text eol=lf
*.godot  text eol=lf
*.cfg    text eol=lf
*.md     text

# Git LFS for binary art & audio assets (Technical Design Doc: Git + LFS).
# These filters are inert until such files exist. Before adding any art, run
# `git lfs install` once on this machine so they're tracked properly.
*.png      filter=lfs diff=lfs merge=lfs -text
*.jpg      filter=lfs diff=lfs merge=lfs -text
*.aseprite filter=lfs diff=lfs merge=lfs -text
*.ase      filter=lfs diff=lfs merge=lfs -text
*.wav      filter=lfs diff=lfs merge=lfs -text
*.ogg      filter=lfs diff=lfs merge=lfs -text
*.mp3      filter=lfs diff=lfs merge=lfs -text
